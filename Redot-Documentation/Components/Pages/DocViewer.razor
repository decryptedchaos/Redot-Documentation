@page "/en/"
@page "/en/{*DocumentPath}"
@layout MainLayout
@using Redot_Documentation.Services
@using Redot_Documentation.Versioning
@using System.Text.RegularExpressions
@inject DocRendererService DocRendererService
@inject VersionManagerService VersionManagerService
@inject IJSRuntime JS


<PageTitle>Introduction</PageTitle>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (errorMessage is not null)
{
    <h3>Unable to load document</h3>
    <p>@errorMessage</p>
}
else
{
    <div class="doc-viewer-layout">
        <article class="doc-viewer-content">
            @((MarkupString)renderedHtml)
        </article>

        @if (tableOfContents.Count > 0)
        {
            <aside class="doc-viewer-toc" aria-label="Quick navigation">
                <h4>On this page</h4>
                <ul>
                    @foreach (var item in tableOfContents)
                    {
                        <li class="toc-level-@(item.Level)">
                            <a href="@BuildTableOfContentsHref(item.Id)">@item.Title</a>
                        </li>
                    }
                </ul>
            </aside>
        }
    </div>
}

@code {
    private static readonly Regex HeadingRegex = new(
        @"<h([1-3])(?<attributes>[^>]*)>(?<content>.*?)</h\1>",
        RegexOptions.IgnoreCase | RegexOptions.Singleline | RegexOptions.Compiled);

    private static readonly Regex IdRegex = new(
        @"\sid\s*=\s*[\""'](?<id>[^\""']+)[\""']",
        RegexOptions.IgnoreCase | RegexOptions.Compiled);

    private static readonly Regex HtmlTagRegex = new(
        @"<[^>]+>",
        RegexOptions.Compiled);

    private static readonly Regex WhitespaceRegex = new(
        @"\s+",
        RegexOptions.Compiled);

    private static readonly Regex InvalidSlugCharacterRegex = new(
        @"[^a-z0-9\-_ ]",
        RegexOptions.Compiled);

    [Parameter]
    public string? DocumentPath { get; set; }

    private bool isLoading = true;
    private string renderedHtml = string.Empty;
    private string? errorMessage;
    private List<TableOfContentsItem> tableOfContents = [];

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var (versionProvider, docPath) = ResolveVersionProviderAndDocumentPath();
            var path = string.IsNullOrWhiteSpace(docPath)
                ? "index.md"
                : docPath.EndsWith(".md", StringComparison.OrdinalIgnoreCase)
                    ? docPath
                    : $"{docPath}.md";

            var html = await DocRendererService.RenderToHtmlAsync(path, versionProvider);
            renderedHtml = BuildTableOfContentsAndEnsureHeadingIds(html);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            tableOfContents.Clear();
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("highlightCode");
    }

    private (VersionProvider provider, string path) ResolveVersionProviderAndDocumentPath()
    {
        var normalizedPath = (DocumentPath ?? string.Empty).Trim('/');
        if (string.IsNullOrWhiteSpace(normalizedPath))
        {
            return (VersionManagerService.GetVersionProvider("latest"), normalizedPath);
        }

        var segments = normalizedPath.Split('/', StringSplitOptions.RemoveEmptyEntries);
        var versionSegment = segments[0];

        var matchedVersion = VersionManagerService.Versions
            .FirstOrDefault(v => string.Equals(v, versionSegment, StringComparison.OrdinalIgnoreCase));
        if (matchedVersion is not null)
        {
            var provider = VersionManagerService.GetVersionProvider(matchedVersion);
            var pathWithoutVersion = string.Join('/', segments.Skip(1));
            return (provider, pathWithoutVersion);
        }

        return (VersionManagerService.GetVersionProvider("latest"), normalizedPath);
    }

    private string BuildTableOfContentsAndEnsureHeadingIds(string html)
    {
        tableOfContents.Clear();

        var usedIds = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        return HeadingRegex.Replace(html, match =>
        {
            var level = int.Parse(match.Groups[1].Value);
            var attributes = match.Groups["attributes"].Value;
            var content = match.Groups["content"].Value;
            var title = DecodeHeadingTitle(content);

            var existingIdMatch = IdRegex.Match(attributes);
            if (string.IsNullOrWhiteSpace(title))
            {
                if (existingIdMatch.Success)
                {
                    usedIds.Add(existingIdMatch.Groups["id"].Value);
                }
                return match.Value;
            }
            var id = existingIdMatch.Success
                ? existingIdMatch.Groups["id"].Value
                : BuildSlug(title);

            id = EnsureUniqueId(id, usedIds);

            if (existingIdMatch.Success && !string.Equals(existingIdMatch.Groups["id"].Value, id, StringComparison.Ordinal))
            {
                attributes = IdRegex.Replace(attributes, $" id=\"{id}\"", 1);
            }
            else if (!existingIdMatch.Success)
            {
                attributes = $" id=\"{id}\"{attributes}";
            }

            tableOfContents.Add(new TableOfContentsItem(level, id, title));
            return $"<h{level}{attributes}>{content}</h{level}>";
        });
    }

    private static string DecodeHeadingTitle(string content)
    {
        var withoutTags = HtmlTagRegex.Replace(content, string.Empty);
        var decoded = System.Net.WebUtility.HtmlDecode(withoutTags);
        return WhitespaceRegex.Replace(decoded, " ").Trim();
    }

    private static string BuildSlug(string title)
    {
        var lowercaseTitle = title.ToLowerInvariant();
        var cleaned = InvalidSlugCharacterRegex.Replace(lowercaseTitle, string.Empty);
        var slug = WhitespaceRegex.Replace(cleaned, "-").Trim('-');
        return string.IsNullOrWhiteSpace(slug) ? "section" : slug;
    }

    private static string EnsureUniqueId(string id, HashSet<string> usedIds)
    {
        var normalizedId = string.IsNullOrWhiteSpace(id) ? "section" : id;
        if (usedIds.Add(normalizedId))
        {
            return normalizedId;
        }

        var suffix = 2;
        while (!usedIds.Add($"{normalizedId}-{suffix}"))
        {
            suffix++;
        }

        return $"{normalizedId}-{suffix}";
    }

    private string BuildTableOfContentsHref(string id)
    {
        var normalizedPath = (DocumentPath ?? string.Empty).Trim('/');
        if (normalizedPath.EndsWith(".md", StringComparison.OrdinalIgnoreCase))
        {
            normalizedPath = normalizedPath[..^3];
        }

        var pagePath = string.IsNullOrWhiteSpace(normalizedPath)
            ? "/en/"
            : $"/en/{normalizedPath}";

        return $"{pagePath}#{Uri.EscapeDataString(id)}";
    }

    private sealed record TableOfContentsItem(int Level, string Id, string Title);
}