@page "/en/latest/About/introduction"
@layout MainLayout
@using Redot_Documentation.Services
@inject DocRendererService DocRendererService


<PageTitle>Introduction</PageTitle>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (errorMessage is not null)
{
    <h3>Unable to load document</h3>
    <p>@errorMessage</p>
}
else
{
    @((MarkupString)renderedHtml)
}

@code {
    private bool isLoading = true;
    private string renderedHtml = string.Empty;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            renderedHtml = await DocRendererService.RenderToHtmlAsync("latest/About/introduction.md");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}